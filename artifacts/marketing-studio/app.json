{
  "expo": {
    "name": "Marketing Content Studio",
    "slug": "marketing-studio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "marketing-studio",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.startupanthology.marketingstudio",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "UIStatusBarStyle": "UIStatusBarStyleLightContent",
        "UIViewControllerBasedStatusBarAppearance": false
      },
      "splash": {
        "backgroundColor": "#000000",
        "resizeMode": "contain",
        "image": "./assets/images/splash-icon.png"
      }
    },
    "android": {},
    "web": {
      "favicon": "./assets/images/favicon.png",
      "name": "Marketing Content Studio",
      "shortName": "Studio",
      "description": "Startup Anthology Marketing Content Studio",
      "themeColor": "#000000",
      "backgroundColor": "#000000"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
